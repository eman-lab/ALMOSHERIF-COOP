<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "{{categoryUrl}}#collectionpage",
  "url": "{{categoryUrl}}",
  "name": "{{categoryName}}",
  "description": "{{categoryDescription}}",
  "mainEntity": {
    "@type": "ItemList",
    "itemListOrder": "https://schema.org/ItemListOrderAscending",
    "numberOfItems": {{displayedSubCategoriesCount}},
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "url": "{{subCategory1Url}}",
        "name": "{{subCategory1Name}}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "url": "{{subCategory2Url}}",
        "name": "{{subCategory2Name}}"
      }
    ]
  }
}
</script>
