<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "{{subCategoryUrl}}#collectionpage",
  "url": "{{subCategoryUrl}}",
  "name": "{{subCategoryName}}",
  "description": "{{subCategoryDescription}}",
  "isPartOf": {
    "@type": "CollectionPage",
    "@id": "{{categoryUrl}}#collectionpage",
    "name": "{{categoryName}}",
    "url": "{{categoryUrl}}"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListOrder": "https://schema.org/ItemListOrderAscending",
    "numberOfItems": {{displayedProductsCount}},
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "url": "{{product1Url}}",
        "name": "{{product1Name}}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "url": "{{product2Url}}",
        "name": "{{product2Name}}"
      }
    ]
  }
}
</script>
