<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "{{subCategoryUrl}}",
  "url": "{{subCategoryUrl}}",
  "name": "{{subCategoryName}}",
  "description": "{{subCategoryDescription}}",
  "isPartOf": {
    "@type": "CollectionPage",
    "name": "{{categoryName}}",
    "url": "{{categoryUrl}}"
  },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{totalProducts}},
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "url": "{{product1Url}}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "url": "{{product2Url}}"
      }
    ]
  }
}
</script>
