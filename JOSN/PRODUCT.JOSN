{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{productUrl}}",
  "name": "{{productName}}",
  "description": "{{productDescription}}",
  "image": [
    "{{productImage}}"
  ],
  "sku": "{{sku}}",
  "gtin13": "{{barcode}}",
  "category": "{{categoryName}}",

  "brand": {
    "@type": "Brand",
    "name": "{{brandName}}"
  },

  "weight": {
    "@type": "QuantitativeValue",
    "value": "{{weightValue}}",
    "unitCode": "{{weightUnitCode}}"
  },

  "offers": {
    "@type": "Offer",
    "url": "{{productUrl}}",
    "priceCurrency": "AED",
    "price": "{{price}}",
    "availability": "{{availability}}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "{{providerName}}"
    }
  }
}
